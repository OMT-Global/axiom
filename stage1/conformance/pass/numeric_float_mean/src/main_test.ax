fn sum3(values: [f64]): f64 {
return values[0] + values[1] + values[2]
}

fn mean3(values: [f64]): f64 {
return sum3(values) / 3.0f64
}

fn area(width: f64, height: f64): f64 {
return width * height
}

let samples: [f64] = [1.0f64, 2.0f64, 3.0f64]
let mean: f64 = mean3(samples) as f64
let total: f64 = sum3([1.0f64, 2.0f64, 3.0f64])
let covered: f64 = area(2.0f64, 3.0f64)
let ratio: f32 = 1.5f32
let ratio64: f64 = ratio as f64

print total as int
print covered as int
print mean as int
print total > 5.5f64
print ratio64 < 2.0f64

fn describe_option(value: Option<string>): string {
return match value { Some(text) => text, None => "missing" }
}

fn describe_result(value: Result<int, string>): string {
return match value { Ok(count) => "ok", Err(message) => message }
}

let present: string = describe_option(Some("ready"))
let missing: string = describe_option(None)
let ok: string = describe_result(Ok(7))
let err: string = describe_result(Err("failed"))
print present
print missing
print ok
print err


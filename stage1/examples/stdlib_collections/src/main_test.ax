import "std/collections.ax"

let numbers: [int] = [4, 5, 6, 7]
print count<int>(numbers[:])
print is_empty<int>(numbers[:])
print has_items<int>(numbers[:])

let middle: &[int] = window<int>(numbers[:], 1, 3)
print count<int>(middle)
print first(middle)
print last(middle)

let prefix: &[int] = take<int>(numbers[:], 2)
print last(prefix)

let suffix: &[int] = skip<int>(numbers[:], 2)
print first(suffix)

let words: [string] = ["build", "test", "ship"]
print count<string>(words[:])
let empty_words: &[string] = take<string>(words[:], 0)
print is_empty<string>(empty_words)

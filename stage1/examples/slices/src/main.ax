fn tail_len(values: &[string]): int {
let tail: &[string] = values[1:]
return len(tail)
}

let values: [int] = [3, 7, 9, 11]
let middle: &[int] = values[1:3]
let prefix: &[int] = values[:2]
let tail: &[int] = values[2:]

print middle[0]
print prefix[1]
print tail[0]
print len(values[:])

let labels: [string] = ["build", "test", "ship"]
print tail_len(labels[:])

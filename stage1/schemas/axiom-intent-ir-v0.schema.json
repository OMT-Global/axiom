{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://axiom-lang.dev/schemas/axiom-intent-ir-v0.schema.json",
  "title": "Axiom Intent IR v0",
  "type": "object",
  "required": ["schema_version", "graph_id", "package", "nodes", "edges"],
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "const": "axiom.intent_ir.v0"
    },
    "graph_id": {
      "type": "string",
      "pattern": "^axiom://graph/[A-Za-z0-9._-]+$"
    },
    "package": {
      "$ref": "#/$defs/nodeId"
    },
    "nodes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/node"
      }
    },
    "edges": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/edge"
      }
    }
  },
  "$defs": {
    "nodeId": {
      "type": "string",
      "pattern": "^axiom://[A-Za-z0-9._~:/#@!$&'()*+,;=%-]+$"
    },
    "nodeKind": {
      "enum": [
        "Package",
        "Module",
        "Type",
        "Function",
        "Capability",
        "Effect",
        "Axiom",
        "Evidence",
        "Artifact",
        "Decision",
        "Dependency",
        "RuntimeSurface"
      ]
    },
    "edgeKind": {
      "enum": [
        "declares",
        "uses",
        "requires",
        "preserves",
        "allows_effect",
        "emits",
        "verified_by",
        "generated_from",
        "depends_on",
        "implements",
        "violates"
      ]
    },
    "node": {
      "type": "object",
      "required": ["id", "kind", "name"],
      "additionalProperties": false,
      "properties": {
        "id": {
          "$ref": "#/$defs/nodeId"
        },
        "kind": {
          "$ref": "#/$defs/nodeKind"
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string"
        },
        "source_span": {
          "$ref": "#/$defs/sourceSpan"
        },
        "metadata": {
          "type": "object",
          "additionalProperties": true
        }
      }
    },
    "edge": {
      "type": "object",
      "required": ["from", "kind", "to"],
      "additionalProperties": false,
      "properties": {
        "from": {
          "$ref": "#/$defs/nodeId"
        },
        "kind": {
          "$ref": "#/$defs/edgeKind"
        },
        "to": {
          "$ref": "#/$defs/nodeId"
        },
        "description": {
          "type": "string"
        },
        "metadata": {
          "type": "object",
          "additionalProperties": true
        }
      }
    },
    "sourceSpan": {
      "type": "object",
      "required": ["path"],
      "additionalProperties": false,
      "properties": {
        "path": {
          "type": "string",
          "minLength": 1
        },
        "line": {
          "type": "integer",
          "minimum": 1
        },
        "column": {
          "type": "integer",
          "minimum": 1
        },
        "end_line": {
          "type": "integer",
          "minimum": 1
        },
        "end_column": {
          "type": "integer",
          "minimum": 1
        }
      }
    }
  }
}
